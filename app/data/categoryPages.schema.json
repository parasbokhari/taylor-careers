{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Taylor Careers Category Pages",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "slug",
      "category",
      "workday_internal_names",
      "icon_raw",
      "icon_badge",
      "heading",
      "description",
      "featured_image",
      "meta_title",
      "meta_description",
      "faqs"
    ],
    "properties": {
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "category": {
        "type": "string",
        "minLength": 1
      },
      "workday_internal_names": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "icon_raw": {
        "type": "string",
        "description": "Public image path or remote image URL for the raw/no-background category icon."
      },
      "icon_badge": {
        "type": "string",
        "description": "Public image path or remote image URL for the badge/background category icon."
      },
      "heading": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string"
      },
      "featured_image": {
        "type": "string"
      },
      "meta_title": {
        "type": "string",
        "minLength": 1
      },
      "meta_description": {
        "type": "string",
        "minLength": 1
      },
      "faqs": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["question", "answer"],
          "properties": {
            "question": {
              "type": "string",
              "minLength": 1
            },
            "answer": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
